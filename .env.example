# Public service
BIAN_BIND_ADDRESS=127.0.0.1
BIAN_PUBLIC_PORT=8000
BIAN_LOG_LEVEL=INFO
BIAN_SSE_MAX_SECONDS=300
BIAN_SSE_MAX_CLIENTS=12
BIAN_HTTP_MAX_CONCURRENT_REQUESTS=32
BIAN_HTTP_REQUEST_QUEUE_SIZE=64
BIAN_HTTP_REQUEST_TIMEOUT_SECONDS=15
BIAN_REALTIME_STALE_SECONDS=45
BIAN_EXPOSE_ERROR_DETAILS=0

# Authentication
BIAN_AUTH_ENABLED=1
BIAN_AUTH_BOOTSTRAP_USER=admin
BIAN_AUTH_BOOTSTRAP_PASSWORD=
BIAN_AUTH_SESSION_TTL_SECONDS=604800
BIAN_AUTH_COOKIE_SECURE=1
BIAN_AUTH_MAX_FAILURES=8
BIAN_AUTH_LOCKOUT_SECONDS=300
BIAN_AUTH_TRUST_PROXY_HEADERS=0
BIAN_AUTH_SESSION_TOUCH_INTERVAL_SECONDS=60
BIAN_AUTH_REQUIRE_SAME_ORIGIN_POST=1

# MySQL
BIAN_STORAGE_USER_ID=default
BIAN_MYSQL_USER=bian
BIAN_MYSQL_PASSWORD=bian_local_password_change_me
BIAN_MYSQL_ROOT_PASSWORD=bian_root_password_change_me
BIAN_MYSQL_DATABASE=bian_dashboard
BIAN_MYSQL_CONNECT_TIMEOUT_SECONDS=3
BIAN_MYSQL_READ_TIMEOUT_SECONDS=5
BIAN_MYSQL_WRITE_TIMEOUT_SECONDS=5
BIAN_STRATEGY_SNAPSHOT_LIMIT=1000

# Redis
BIAN_REDIS_DB=0
BIAN_REDIS_PASSWORD=
BIAN_REDIS_CONNECT_TIMEOUT_SECONDS=2
BIAN_REDIS_READ_TIMEOUT_SECONDS=2

# Live signal review
BIAN_SIGNAL_REVIEW_LIMIT=5000
BIAN_SIGNAL_REVIEW_TRIGGER_MIN_INTERVAL_SECONDS=20
BIAN_SIGNAL_REVIEW_TAKER_FEE_BPS=5
BIAN_SIGNAL_REVIEW_SLIPPAGE_BPS=2
